{
  "env": {
    "browser": true,
    "es2022": true
  },
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module"
  },
  "rules": {
    "no-unused-vars": "warn",
    "no-console": "off",
    "prefer-const": "error",
    "arrow-spacing": "error",
    "no-multiple-empty-lines": "warn",
    "semi": ["error", "always"],
    "quotes": ["error", "single"]
  }
}
